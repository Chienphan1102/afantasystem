# ╔══════════════════════════════════════════════════════════════╗
# ║ AFANTA — Mẫu cấu hình môi trường                              ║
# ║ Copy file này thành ".env" rồi điền giá trị thật vào.         ║
# ║ TUYỆT ĐỐI KHÔNG commit file ".env" lên Git.                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh
APP_NAME=AFANTA
APP_DOMAIN=afantaAi.com

# ─── Database (Supabase Postgres) ─────────────────────────────
# Lấy từ Supabase Dashboard → Connect → Session pooler → URI
# Format: postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Direct connection (cho prisma migrate, ít dùng hơn)
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Supabase REST API ────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<paste-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key>

# ─── Redis Queue (Upstash REST API) ───────────────────────────
UPSTASH_REDIS_REST_URL=https://<your-redis>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<paste-rest-token>

# ─── Seed (chỉ dùng `pnpm prisma db seed`) ────────────────────
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=ChangeMe123!
SEED_TENANT_NAME=Demo Media Co.
SEED_TENANT_SLUG=demo-media-co

# ─── JWT Auth ─────────────────────────────────────────────────
# Sinh chuỗi random 256-bit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<change-me-256-bit-hex>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption (Phase 1 dùng env, Phase 3 chuyển HashiCorp Vault) ──
# KEK = Key Encryption Key, dùng để wrap DEK (Data Encryption Key)
# Sinh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEK_DEV=<change-me-256-bit-hex>

ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# ─── API Server ───────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173

# ─── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=AFANTA

# ─── Object Storage (Phase 2+) ────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Email (Phase 2 — gửi OTP, alert) ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@afantaai.com

# ─── Telegram bot (Phase 2 — alert) ───────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Sentry (Phase 2 — error tracking) ────────────────────────
SENTRY_DSN=

# ─── Proxy provider (Phase 2 — chỉ khi cần) ───────────────────
BRIGHT_DATA_USER=
BRIGHT_DATA_PASS=

# ─── YouTube Official API (Phase 1 cuối) ──────────────────────
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
