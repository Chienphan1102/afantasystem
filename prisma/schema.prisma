// AFANTA — Database Schema (Prisma)
// Reference: AFANTA_MASTER_PLAN_v2.md sections B (architecture), E (RBAC), L (multi-tenant).
//
// Conventions:
//   - id        : cuid() (no auto-increment, avoid information leakage)
//   - timestamps: createdAt + updatedAt on every business model
//   - tenantId  : present on every tenant-scoped model (multi-tenant + future RLS)
//   - cascade   : onDelete behaviour chosen per relation
//
// Phase 1 Cloud-first:
//   - DATABASE_URL points at Supabase Session Pooler (port 5432).
//   - directUrl not configured yet (will add Phase 2 if we move to transaction pooler).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ ENUMS                                                         ║
// ╚══════════════════════════════════════════════════════════════╝

enum PlatformName {
  YOUTUBE
  FACEBOOK_PAGE
  FACEBOOK_GROUP
  INSTAGRAM
  TIKTOK
  TIKTOK_SHOP
  TELEGRAM
  X_TWITTER
  LINKEDIN
  PINTEREST
  THREADS
  WHATSAPP_BUSINESS
  ZALO_OA
  SHOPEE
  LAZADA
  TIKI
}

enum RoleType {
  OWNER
  SUPER_ADMIN
  GROUP_ADMIN
  TEAM_LEAD
  USER
  VIEWER
  CUSTOM
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRYING
  CANCELLED
}

enum JobPriority {
  HIGH
  NORMAL
  LOW
}

enum ProxyType {
  DATACENTER
  RESIDENTIAL_ROTATING
  RESIDENTIAL_STICKY
  MOBILE
  ISP
}

enum ProxyStatus {
  HEALTHY
  DEGRADED
  DEAD
}

enum AccountStatus {
  ACTIVE
  CHECKPOINT
  EXPIRED
  DISABLED
  REVOKED
}

enum ChannelStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AuditResult {
  SUCCESS
  FAIL
  BLOCKED
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ TENANT (multi-tenant root)                                    ║
// ╚══════════════════════════════════════════════════════════════╝

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  groups           Group[]
  roles            Role[]
  platformAccounts PlatformAccount[]
  channels         Channel[]
  auditLogs        AuditLog[]
  alertRules       AlertRule[]
  proxyAssignments ProxyAssignment[]

  @@index([slug])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ USER & ORG STRUCTURE                                          ║
// ╚══════════════════════════════════════════════════════════════╝

model User {
  id                  String    @id @default(cuid())
  tenantId            String
  email               String
  hashedPassword      String
  fullName            String?
  totpSecret          String? // encrypted at rest
  totpEnabled         Boolean   @default(false)
  masterPasswordSalt  Bytes? // for Argon2id KDF (Phase 1 server-side; Phase 3 client-side)
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles          UserRole[]
  groupMembers       GroupMember[]
  ownedAccounts      PlatformAccount[]   @relation("PlatformAccountOwner")
  channelAssignments ChannelAssignment[]
  scrapeJobs         ScrapeJob[]
  auditLogs          AuditLog[]
  alertRules         AlertRule[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

model Group {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teams     Team[]
  members   GroupMember[]
  userRoles UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Team {
  id        String   @id @default(cuid())
  groupId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ RBAC                                                          ║
// ╚══════════════════════════════════════════════════════════════╝

model Role {
  id          String    @id @default(cuid())
  tenantId    String? // null for global system roles
  name        String
  type        RoleType
  description String?
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  userRoles   UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([type])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "channel:create"
  category    String // e.g. "CHANNEL", "AUDIT"
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([category])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  id        String    @id @default(cuid())
  userId    String
  roleId    String
  groupId   String? // null = tenant-wide role
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role  Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, groupId])
  @@index([userId])
  @@index([roleId])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ PLATFORM ACCOUNT (encrypted session bundle — TOP SECRET)      ║
// ╚══════════════════════════════════════════════════════════════╝

model PlatformAccount {
  id           String        @id @default(cuid())
  tenantId     String
  ownerUserId  String
  platform     PlatformName
  accountLabel String
  status       AccountStatus @default(ACTIVE)

  // Encrypted bundle (Envelope Encryption — see packages/crypto)
  encryptedBundle Bytes
  wrappedDek      Bytes
  iv              Bytes // AES-GCM IV (12 bytes)
  tag             Bytes // AES-GCM auth tag (16 bytes)
  salt            Bytes // Argon2id salt (16 bytes)
  aad             String

  // Fingerprint (must stay consistent across re-uses)
  fingerprintSeed String
  userAgent       String
  viewport        String // e.g. "1920x1080"
  timezone        String
  acceptLanguage  String

  // Lifecycle
  lastLoginAt    DateTime?
  expiresAt      DateTime?
  lastVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerUser        User              @relation("PlatformAccountOwner", fields: [ownerUserId], references: [id])
  channels         Channel[]
  proxyAssignment  ProxyAssignment?

  @@index([tenantId])
  @@index([ownerUserId])
  @@index([platform])
  @@index([status])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ CHANNEL                                                       ║
// ╚══════════════════════════════════════════════════════════════╝

model Channel {
  id                String        @id @default(cuid())
  tenantId          String
  platformAccountId String
  externalId        String // platform's internal channel/page ID
  name              String
  url               String?
  thumbnailUrl      String?
  // Cached metrics (latest snapshot — for fast list views)
  subscriberCount   BigInt        @default(0)
  totalViews        BigInt        @default(0)
  status            ChannelStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformAccount PlatformAccount     @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  assignments     ChannelAssignment[]
  scrapeJobs      ScrapeJob[]
  insights        ChannelInsight[]

  @@unique([platformAccountId, externalId])
  @@index([tenantId])
  @@index([status])
}

model ChannelAssignment {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  canRead    Boolean  @default(true)
  canWrite   Boolean  @default(false)
  canRescan  Boolean  @default(false)
  assignedAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ SCRAPE JOB & CHANNEL INSIGHT                                  ║
// ╚══════════════════════════════════════════════════════════════╝

model ScrapeJob {
  id                 String      @id @default(cuid())
  channelId          String
  status             JobStatus   @default(PENDING)
  priority           JobPriority @default(NORMAL)
  triggeredByUserId  String?
  workerId           String?
  startedAt          DateTime?
  finishedAt         DateTime?
  errorMsg           String?
  retryCount         Int         @default(0)
  createdAt          DateTime    @default(now())

  channel           Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  triggeredByUser   User?           @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  insight           ChannelInsight?

  @@index([channelId])
  @@index([status])
  @@index([createdAt])
}

model ChannelInsight {
  id                  String   @id @default(cuid())
  channelId           String
  scrapeJobId         String?  @unique
  // Core metrics (Phase 1 minimum)
  subscriberCount     BigInt
  totalViews          BigInt
  watchTimeMinutes    BigInt   @default(0)
  estimatedRevenueUsd Decimal? @db.Decimal(12, 2)
  // Platform-specific data (CTR, AVD, retention curves, ...)
  rawData             Json?
  // Capture metadata
  capturedAt          DateTime @default(now())
  hash                String // SHA-256 of (channelId + capturedMinute) — dedup

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  scrapeJob ScrapeJob? @relation(fields: [scrapeJobId], references: [id], onDelete: SetNull)

  @@index([channelId, capturedAt])
  @@index([hash])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ PROXY POOL & ASSIGNMENT                                       ║
// ╚══════════════════════════════════════════════════════════════╝

model ProxyPool {
  id                String      @id @default(cuid())
  type              ProxyType
  endpoint          String // host:port
  username          String?
  passwordEncrypted Bytes? // AES-GCM encrypted by KEK
  country           String // ISO-2
  region            String?
  provider          String? // e.g. "BrightData"
  status            ProxyStatus @default(HEALTHY)
  latencyMs         Int?
  successRate       Float?
  lastCheckAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  assignments ProxyAssignment[]

  @@index([type, status])
  @@index([country])
}

model ProxyAssignment {
  id                String   @id @default(cuid())
  tenantId          String
  platformAccountId String   @unique // 1:1 — sticky proxy per cookie
  proxyId           String
  assignedAt        DateTime @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformAccount PlatformAccount @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  proxy           ProxyPool       @relation(fields: [proxyId], references: [id], onDelete: Restrict)

  @@index([proxyId])
  @@index([tenantId])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ AUDIT LOG (append-only, immutable)                            ║
// ╚══════════════════════════════════════════════════════════════╝

model AuditLog {
  id           String      @id @default(cuid())
  tenantId     String
  userId       String?
  action       String // e.g. "channel.delete", "auth.login"
  resourceType String? // e.g. "Channel", "User"
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  result       AuditResult
  metadata     Json?
  occurredAt   DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt])
  @@index([userId])
  @@index([action])
}

// ╔══════════════════════════════════════════════════════════════╗
// ║ ALERT RULE & EVENT                                            ║
// ╚══════════════════════════════════════════════════════════════╝

model AlertRule {
  id              String   @id @default(cuid())
  tenantId        String
  createdByUserId String
  name            String
  description     String?
  // Condition DSL JSON, e.g. { metric: "subscribers", op: "drop_pct", threshold: 5, window: "24h" }
  condition       Json
  // Target channels (can be empty = all)
  channelIds      String[] @default([])
  // Notification fanout
  notifyChannels  String[] @default([]) // ["email", "telegram", "in-app"]
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  events      AlertEvent[]

  @@index([tenantId])
  @@index([enabled])
}

model AlertEvent {
  id             String    @id @default(cuid())
  ruleId         String
  triggeredAt    DateTime  @default(now())
  payload        Json // values that triggered
  deliveredAt    DateTime?
  acknowledgedAt DateTime?

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, triggeredAt])
}
